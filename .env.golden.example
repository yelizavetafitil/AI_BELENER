# Режим проверки в вебе по эталонам: только OCR/Surya, без vision и LLM
# copy .env.golden.example .env
# docker compose -f docker-compose.yml -f docker-compose.surya.yml --profile surya up -d

WEB_PORT=8090
PDF_LOCAL_ONLY=1
PDF_REPORT_FAITHFUL=1
PDF_REPORT_LLM=0
PDF_REPORT_FULL_TEXT=0
PDF_REPORT_QUALITY=0
PDF_REPORT_BODY=0
PDF_EXTRACT_MODE=fast
PDF_OCR_ENGINE=tesseract
PDF_OCR_FALLBACK_TESS=1

PDF_VISION_MODE=off
PDF_VISION_ZONES=0
PDF_VISION_POST=0
PDF_VISION_STAMP=0
PDF_VISION_TABLES=0
PDF_SHEET_TEXT_VISION=0
PDF_LAYOUT_VISION=0
PDF_SCAN_VISION_FIRST=0

PDF_CV_ZONE_REFINE=1
PDF_DISCOVER_ZONES_FAST=1
PDF_STAMP_GRID=1
PDF_TABLE_DPI=420
PDF_STAMP_BLOCK_DPI=480
