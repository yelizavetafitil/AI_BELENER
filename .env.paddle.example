# Локальный PaddleOCR для зон spec_* / stamp_frame (fine-tuned rec)
# cp .env.paddle.example .env
# docker compose -f docker-compose.yml -f docker-compose.paddle.yml --profile paddle up -d --build

WEB_PORT=8090
WEB_MEM_LIMIT=6g
PADDLE_MEM_LIMIT=4g
PADDLE_ADAPTER_PORT=8082

PDF_LOCAL_ONLY=1
PDF_REPORT_FAITHFUL=1
PDF_VISION_MODE=off
PDF_VISION_POST=0
PDF_VISION_TABLES=0
PDF_EXTRACT_MODE=fast
PDF_CV_ZONE_REFINE=1
PDF_STAMP_GRID=1

# Tesseract для прочих зон; Paddle — только spec/stamp
PDF_OCR_ENGINE=tesseract
PDF_OCR_PADDLE_ZONES=1
PDF_OCR_FALLBACK_TESS=1
PADDLE_OCR_URL=http://paddle-ocr:8082
PADDLE_OCR_TIMEOUT=120
# После train_paddle_rec — inference rec:
PADDLE_REC_MODEL_DIR=/models/rec_finetuned

# YOLO (после scripts/retrain_all.ps1 или train_yolo_zones.py)
PDF_YOLO_ZONES=1
PDF_YOLO_MODEL=/app/data/training/yolo_zones/runs/train/weights/best.pt
PDF_YOLO_CONF=0.35

# GPU Paddle (docker-compose.paddle.gpu.yml + NVIDIA Container Toolkit)
# PADDLE_USE_GPU=1
