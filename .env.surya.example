# Локальный пайплайн: Surya-OCR + честный отчёт (без облака и vision-таблиц)
# cp .env.surya.example .env
# docker compose -f docker-compose.yml -f docker-compose.surya.yml --profile surya up -d --build

WEB_PORT=8090
WEB_MEM_LIMIT=6g
WEB_MEM_RESERVATION=1536m
DB_MEM_LIMIT=1024m

PDF_LOCAL_ONLY=1
PDF_REPORT_FAITHFUL=1
PDF_REPORT_LLM=0
PDF_REPORT_FULL_TEXT=0
PDF_REPORT_QUALITY=0
PDF_REPORT_BODY=0
PDF_EXTRACT_MODE=accuracy

PDF_OCR_ENGINE=surya
SURYA_OCR_URL=http://surya-ocr:8081
SURYA_OCR_TIMEOUT=300
PDF_OCR_FALLBACK_TESS=1

PDF_VISION_MODE=off
PDF_VISION_ZONES=0
PDF_VISION_TABLES=0
PDF_VISION_POST=0
PDF_SHEET_TEXT_VISION=0
PDF_LAYOUT_VISION=0
PDF_SCAN_VISION_FIRST=0

PDF_OCR_DESKEW=1
PDF_OCR_MULTIVIEW=1
PDF_OCR_MULTIVIEW_FAST=1
PDF_OCR_MULTIVIEW_SURYA=0
PDF_DISCOVER_ZONES_FAST=1
PDF_DISCOVER_MULTIDPI=1
PDF_STAMP_GRID=1
PDF_TABLE_CLAHE=1
PDF_CV_CELLS=1
PDF_CV_TABLES=1
PDF_CV_ZONE_REFINE=1
PDF_IMG2TABLE_ZONE=0
PDF_IMG2TABLE_SPEC=0
PDF_IMG2TABLE_WHEN_WEAK=0

PDF_STAMP_DPI=720
PDF_TABLE_DPI=560
PDF_STAMP_FRAC=0.30
PDF_RIGHT_FRAC=0.44

SURYA_MEM_LIMIT=8g
SURYA_MEM_RESERVATION=2g
SURYA_DEVICE=cpu
SURYA_MAX_SIDE=2048
SURYA_ADAPTER_PORT=8081

# Опционально штамп eDOCr:
# docker compose --profile edocr up -d
# EDOCR_URL=http://edocr:5001
