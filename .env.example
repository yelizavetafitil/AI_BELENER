# БелнипиAI — accuracy (по умолчанию) или fast
# Copy-Item .env.example .env -Force && docker compose up --build -d

WEB_PORT=8090

# Память Docker (лимит = потолок, reservation = гарантированный минимум)
WEB_MEM_LIMIT=6g
WEB_MEM_RESERVATION=1536m
DB_MEM_LIMIT=1024m
DB_MEM_RESERVATION=256m
# С vision: docker compose --profile ollama up -d
OLLAMA_MEM_LIMIT=8g
OLLAMA_MEM_RESERVATION=2g

MODEL_DEFAULT=gemma3:4b
MODEL_DRAWING=gemma3:4b
OLLAMA_HOST=http://ollama:11434

PDF_EXTRACT_MODE=accuracy

PDF_SCAN_VISION_FIRST=0
PDF_DISCOVER_ZONES=0
PDF_DISCOVER_ZONES_FAST=1
PDF_OCR_DESKEW=1
PDF_LAYOUT_OCR=0
PDF_LAYOUT_VISION=0

PDF_STAMP_BLOCK_DPI=480
PDF_STAMP_GRID=1
PDF_TABLE_DPI=520
PDF_CV_TABLES=1
PDF_CV_TABLES_ALWAYS=0
PDF_IMG2TABLE=0
PDF_IMG2TABLE_WHEN_WEAK=1
PDF_CV_TABLES_DPI=420
PDF_CV_CELLS=1

PDF_VISION_MODE=auto
PDF_VISION_ZONES=1
# Таблицы только OCR (vision часто «додумывает» QF1/TL1…). Включить: PDF_VISION_TABLES=1
PDF_VISION_TABLES=0
PDF_VISION_POST=1
# Таблицы: CLAHE + img2table по зоне при слабом OCR (локально)
PDF_TABLE_CLAHE=1
PDF_IMG2TABLE_ZONE=1
PDF_IMG2TABLE_SPEC=1
PDF_TABLE_DPI=560
PDF_VISION_COMBINED=1
PDF_VISION_MODEL=qwen2.5vl:7b
PDF_VISION_TIMEOUT=300
PDF_SHEET_TEXT_VISION=1
PDF_BODY_OCR=1
PDF_BODY_OCR_TILED=1

# docker compose --profile edocr up -d --build
EDOCR_URL=http://edocr:5001

# === Локально без облака (рекомендуется) — docs/LOCAL_OCR_PIPELINE.md ===
PDF_LOCAL_ONLY=1
PDF_REPORT_FAITHFUL=1
PDF_REPORT_LLM=0
PDF_VISION_MODE=off
PDF_VISION_TABLES=0
PDF_VISION_POST=0
PDF_SHEET_TEXT_VISION=0

# Surya OCR (CPU, AMD/Intel): cp .env.surya.example .env
# docker compose -f docker-compose.yml -f docker-compose.surya.yml --profile surya up -d --build
# PDF_OCR_ENGINE=surya
# SURYA_OCR_URL=http://surya-ocr:8081

# DeepSeek (только NVIDIA GPU) — docs/DEPLOY_LINUX_DEEPSEEK.md
# PDF_OCR_ENGINE=deepseek
# DEEPSEEK_OCR_URL=http://deepseek-ocr:8080

PDF_OCR_ENGINE=tesseract
PDF_OCR_FALLBACK_TESS=1

# Поячеечный OCR перечня (OpenCV-сетка, как engineering-drawing-extractor)
PDF_CV_CELLS=1

# PDF_REPORT_FAITHFUL=1 — без LLM-полировки (нет подгонки)
PDF_REPORT_FAITHFUL=1
PDF_REPORT_LLM=0
PDF_STAMP_UNIVERSAL=0
