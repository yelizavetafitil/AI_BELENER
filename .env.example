# БелнипиAI — проверка ГОСТ на листе (Docker)
# Windows: Copy-Item .env.example .env
# Linux:   cp .env.example .env
# Запуск:  .\scripts\up_gost_stack.ps1
# или:     docker compose -f docker-compose.yml -f docker-compose.ssd.yml -f docker-compose.fast.yml up -d --build

WEB_PORT=8090

# Кэш рендера тайлов OCR на быстром SSD (Windows: G:/BelenerCache)
BELENER_SSD_ROOT=G:/BelenerCache
PDF_ZONE_CACHE=1

# Память контейнеров
WEB_MEM_LIMIT=6g
WEB_MEM_RESERVATION=1536m
DB_MEM_LIMIT=1024m
DB_MEM_RESERVATION=256m

# Локально, без облака
PDF_LOCAL_ONLY=1
PDF_REPORT_LLM=0
PDF_OCR_ENGINE=tesseract

# Проверка актуальности на normy.stn.by (ИПС)
PDF_STN_LOOKUP=1
PDF_STN_BASE_URL=https://normy.stn.by
PDF_STN_LOGIN=
PDF_STN_PASSWORD=
PDF_STN_TIMEOUT=15
PDF_STN_PARALLEL=1
PDF_STN_MAX_REFS=50

# OCR нормативов: сетка тайлов по листу (полнота списка)
PDF_TILE_OCR_DPI=320
PDF_TILE_OCR_TIME_BUDGET=300
PDF_TILE_OCR_OVERLAP=0.15
PDF_TILE_OCR_PSM=6
PDF_TILE_TEXT_SKIP_OCR_MIN=0
PDF_NORMATIVE_FORCE_OCR=1
PDF_NORMATIVE_SKIP_TILES_MIN_REFS=0
PDF_GOST_CHECK_BUDGET=300
PDF_GOST_EXTRA_PER_PAGE_SEC=21
PDF_STN_BATCH_BUDGET=60
PDF_NORMATIVE_SUPPLEMENT_SEC=28
PDF_NORMATIVE_WIDE_DPI_BOOST=1.15

# Загрузки PDF — /app/data/tmp (диск проекта), не переполненный SSD-кэш
