# Полный локальный стек: Surya + Paddle (spec/stamp) + YOLO зон + fast extract
# cp .env.full.example .env
# docker compose -f docker-compose.yml -f docker-compose.surya.yml --profile surya up -d --build
# Один раз (YOLO, ~10–30 мин CPU): python scripts/export_yolo_dataset.py --pdf-dir scan
#                              python scripts/train_yolo_zones.py --epochs 40

WEB_PORT=8090
WEB_MEM_LIMIT=6g
WEB_MEM_RESERVATION=1536m
DB_MEM_LIMIT=1024m
PADDLE_MEM_LIMIT=4g
PADDLE_ADAPTER_PORT=8082

PDF_LOCAL_ONLY=1
PDF_REPORT_FAITHFUL=1
PDF_REPORT_LLM=0
PDF_REPORT_FULL_TEXT=0
PDF_REPORT_QUALITY=0
PDF_REPORT_BODY=0
PDF_VISION_MODE=off
PDF_VISION_ZONES=0
PDF_VISION_POST=0
PDF_VISION_TABLES=0
PDF_SHEET_TEXT_VISION=0
PDF_LAYOUT_VISION=0
PDF_SCAN_VISION_FIRST=0
PDF_DISCOVER_ZONES=0

PDF_EXTRACT_MODE=fast
PDF_BODY_OCR=0
PDF_IMG2TABLE_ZONE=0
PDF_IMG2TABLE_SPEC=0

# OCR: Surya по листу; Paddle — только spec_* и stamp_*; остальное → Tesseract
PDF_OCR_ENGINE=surya
SURYA_OCR_URL=http://surya-ocr:8081
SURYA_OCR_TIMEOUT=300
PADDLE_OCR_URL=http://paddle-ocr:8082
PADDLE_OCR_TIMEOUT=120
PDF_OCR_PADDLE_ZONES=1
PDF_OCR_FALLBACK_TESS=1
PDF_OCR_DESKEW=1
PDF_OCR_MULTIVIEW=0
PDF_OCR_MULTIVIEW_SURYA=0

# YOLO зон (после train_yolo_zones; до обучения — геометрия discover как раньше)
PDF_YOLO_ZONES=1
PDF_YOLO_CONF=0.25
PDF_YOLO_MODEL=/app/data/training/yolo_zones/runs/train/weights/best.pt

PDF_CV_ZONE_REFINE=1
PDF_CV_TABLES=1
PDF_CV_CELLS=0
PDF_DISCOVER_ZONES_FAST=1
PDF_STAMP_GRID=1
PDF_STAMP_DPI=480
PDF_TABLE_DPI=400
PDF_TEXT_LAYER_FAST_MIN=200
PDF_STAMP_FRAC=0.30
PDF_RIGHT_FRAC=0.44

SURYA_MEM_LIMIT=8g
SURYA_DEVICE=cpu
SURYA_MAX_SIDE=2048
SURYA_ADAPTER_PORT=8081
