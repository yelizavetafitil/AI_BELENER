# Точный структурированный вывод БЕЗ долгого accuracy-режима
# Два типа листов:
#   cad_export — nanoCAD/AutoCAD PDF с текстовым слоём (1118-ГП9, GCC, многие VR) → быстрый путь text_layer
#   scan       — чистый скан без слоя → OCR по зонам (Tesseract; Surya опционально)
#
# cp .env.accuracy.example .env
# docker compose -f docker-compose.yml -f docker-compose.surya.yml --profile surya up -d
# python scripts/check_accuracy_setup.py

WEB_PORT=8090
WEB_MEM_LIMIT=6g
WEB_MEM_RESERVATION=1536m
DB_MEM_LIMIT=1024m

# --- Этап 5: faithful, без vision и без дампа всего PDF ---
PDF_LOCAL_ONLY=1
PDF_REPORT_FAITHFUL=1
PDF_REPORT_LLM=0
PDF_REPORT_FULL_TEXT=0
PDF_REPORT_QUALITY=0
PDF_REPORT_BODY=0
PDF_VISION_MODE=off
PDF_VISION_ZONES=0
PDF_VISION_POST=0
PDF_VISION_STAMP=0
PDF_VISION_TABLES=0
PDF_SHEET_TEXT_VISION=0
PDF_LAYOUT_VISION=0
PDF_SCAN_VISION_FIRST=0
PDF_DISCOVER_ZONES=0

# --- Этап 4: БЫСТРО (не accuracy) ---
PDF_EXTRACT_MODE=fast
PDF_BODY_OCR=0
PDF_IMG2TABLE_ZONE=0
PDF_IMG2TABLE_SPEC=0

# --- Этап 3: OCR (Tesseract быстрее; Surya — см. закомментировано ниже) ---
PDF_OCR_ENGINE=tesseract
PDF_OCR_FALLBACK_TESS=1
PDF_OCR_DESKEW=1
PDF_OCR_MULTIVIEW=0
PDF_OCR_MULTIVIEW_FAST=0
PDF_OCR_MULTIVIEW_SURYA=0
# Для тяжёлых чистых сканов раскомментируйте (медленнее, точнее):
# PDF_OCR_ENGINE=surya
# SURYA_OCR_URL=http://surya-ocr:8081
# SURYA_OCR_TIMEOUT=300

# --- Этап 2: зоны (оставляем) ---
PDF_CV_ZONE_REFINE=1
PDF_CV_TABLES=1
PDF_CV_CELLS=0
PDF_DISCOVER_ZONES_FAST=1
PDF_DISCOVER_MULTIDPI=0
PDF_STAMP_GRID=1
PDF_TABLE_CLAHE=0
PDF_STAMP_DPI=480
PDF_TABLE_DPI=400
PDF_TEXT_LAYER_FAST_MIN=200
PDF_STAMP_FRAC=0.30
PDF_RIGHT_FRAC=0.44

SURYA_MEM_LIMIT=8g
SURYA_MEM_RESERVATION=2g
SURYA_DEVICE=cpu
SURYA_MAX_SIDE=2048
SURYA_ADAPTER_PORT=8081
