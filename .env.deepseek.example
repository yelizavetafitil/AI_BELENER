# === Локальный режим + DeepSeek-OCR (Linux, без утечек в облако) ===
# cp .env.deepseek.example .env

WEB_PORT=8090

# --- Память Docker (лимит / резерв). Сумма резервов ≈ минимум для ВМ ---
WEB_MEM_LIMIT=6g
WEB_MEM_RESERVATION=1536m
DB_MEM_LIMIT=1024m
DB_MEM_RESERVATION=256m
DEEPSEEK_ADAPTER_MEM_LIMIT=512m
DEEPSEEK_ADAPTER_MEM_RESERVATION=128m
# vLLM DeepSeek-OCR на GPU (отдельный compose) — в VRAM + ~4–8 GB RAM хоста
DEEPSEEK_VLLM_MEM_HINT=8g

# Строго локально: без vision/LLM-полировки (чертежи не уходят наружу)
PDF_LOCAL_ONLY=1
PDF_REPORT_FAITHFUL=1
PDF_REPORT_LLM=0
PDF_VISION_MODE=off
PDF_VISION_ZONES=0
PDF_VISION_POST=0
PDF_VISION_TABLES=0

# OCR: DeepSeek на вашем GPU + fallback Tesseract в контейнере web
PDF_OCR_ENGINE=deepseek
DEEPSEEK_OCR_URL=http://deepseek-ocr:8080
DEEPSEEK_OCR_PATH=/api/ocr
DEEPSEEK_OCR_TIMEOUT=240
PDF_OCR_FALLBACK_TESS=1

# Точность таблиц/штампа
PDF_EXTRACT_MODE=accuracy
PDF_TABLE_DPI=560
PDF_STAMP_DPI=720
PDF_TABLE_CLAHE=1
PDF_CV_CELLS=1
PDF_OCR_DESKEW=1

# Ollama не запускается (профиль ollama выключен). Не добавляйте --profile ollama
OLLAMA_HOST=http://ollama:11434

# URL vLLM DeepSeek-OCR на GPU-хосте (для адаптера deepseek-ocr)
# Linux Docker: host.docker.internal → GPU-сервис на порту 8000
DEEPSEEK_BACKEND_URL=http://host.docker.internal:8000
DEEPSEEK_ADAPTER_PORT=8080

# БД (локально)
DATABASE_URL=postgresql://belener:belener@db:5432/belnipiai
